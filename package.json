{
  "name": "china-ru",
  "version": "1.0.0",
  "description": "China-RU: Professional international marketplace (React + Node.js)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --no-cache",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "workspace @china-ru/db npm run migrate",
    "db:studio": "workspace @china-ru/db npm run studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.2.5",
    "turbo": "^2.1.0",
    "typescript": "^5.7.2"
  }
}

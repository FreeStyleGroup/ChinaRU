# Database
DATABASE_URL=postgresql://user:password@localhost:5432/china_ru
DATABASE_POOL_MAX=10

# Server
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# Client
NEXT_PUBLIC_API_URL=http://localhost:3001

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_REFRESH_TTL_MOBILE=90d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Security
BCRYPT_COST=10

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=China-RU <no-reply@china-ru.ru>

# AI (AITunnel)
AITUNNEL_API_KEY=sk-...
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1
AITUNNEL_MODEL=gpt-4o-mini

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_api_key

# MinIO / S3
STORAGE_TYPE=minio
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=china-ru
S3_REGION=us-east-1

# Redis
REDIS_URL=redis://localhost:6379/0

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
WECHAT_CLIENT_ID=
WECHAT_CLIENT_SECRET=

# Admin
ADMIN_SECRET_KEY=super_secret_admin_key

# i18n
DEFAULT_LOCALE=ru
SUPPORTED_LOCALES=ru,en,zh

# Feature flags
REGISTRATION_OPEN=true
SELLER_REGISTRATION_OPEN=true
